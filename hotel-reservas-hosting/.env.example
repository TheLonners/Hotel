# Configuracion para produccion. Copia este archivo como .env o define las variables en tu hosting.
PORT=3000
HOST=0.0.0.0
DATABASE_PATH=./data/hotel.sqlite
UPLOADS_DIR=./uploads
BACKUP_DIR=./backups

# Usa exactamente el dominio publico donde serviras esta aplicacion.
CORS_ORIGIN=https://tu-dominio.com

# En un hosting publico debe estar activada.
AUTH_ENABLED=true
# Solo se usa para crear el primer admin en una base nueva y para compatibilidad con clientes antiguos.
ADMIN_PASSWORD=
# Cadena larga, unica y secreta usada para firmar las sesiones.
SESSION_SECRET=

# Opcional: datos de la API de Airbnb Scraper si usas la funcion de detalles de listing.
AIRBNB_SCRAPER_API_URL=https://airbnb-scraper-api.omkar.cloud
AIRBNB_SCRAPER_API_KEY=
AIRBNB_SCRAPER_CURRENCY=USD
