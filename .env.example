# Copia este archivo como .env únicamente EN LA RASPBERRY PI. Nunca lo subas.
PORT=3000
HOST=0.0.0.0
TZ=America/Bogota

# Rutas relativas a /app dentro del contenedor; los bind mounts de compose las persisten.
DATABASE_PATH=./data/hotel.sqlite
UPLOADS_DIR=./uploads
BACKUP_DIR=./backups
DATABASE_BACKUP_DIR=./backups
DATABASE_BUSY_TIMEOUT=5000
DATABASE_ENABLE_WAL=true
DATABASE_SYNCHRONOUS=NORMAL
DATABASE_WAL_AUTOCHECKPOINT=1000
DATABASE_JOURNAL_SIZE_LIMIT=67108864
DATABASE_BACKUP_MAX_AGE_HOURS=26
DATABASE_MIN_FREE_MB=1024
BACKUP_DAILY_RETENTION_DAYS=14
BACKUP_WEEKLY_RETENTION_WEEKS=8
BACKUP_MONTHLY_RETENTION_MONTHS=12
BACKUP_PRUNE_ENABLED=false

# Requerido antes de cualquier acceso remoto. Usa valores largos, únicos y privados.
AUTH_ENABLED=true
ADMIN_PASSWORD=CAMBIAR_POR_UN_SECRETO_LARGO_DE_AL_MENOS_20_CARACTERES
SESSION_SECRET=CAMBIAR_POR_OTRO_SECRETO_LARGO_E_INDEPENDIENTE

# Ajustar cuando exista el hostname final. Al ser misma URL, no es necesario para la LAN.
CORS_ORIGIN=https://hotel-prueba.example.com

# Solo para el perfil `tunnel`. El token se obtiene en Cloudflare y no se versiona.
CLOUDFLARE_TUNNEL_TOKEN=

# Configuración opcional de Airbnb existente.
AIRBNB_SCRAPER_API_URL=https://airbnb-scraper-api.omkar.cloud
AIRBNB_SCRAPER_API_KEY=
AIRBNB_SCRAPER_CURRENCY=USD
