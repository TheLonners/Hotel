PORT=3000
HOST=0.0.0.0
# Ruta relativa a la raíz del proyecto o ruta absoluta. Nunca publiques este archivo con datos reales.
DATABASE_PATH=./data/hotel.sqlite
UPLOADS_DIR=./uploads
# Carpeta persistente fuera del código (por ejemplo D:/HotelBackups)
BACKUP_DIR=
# Alias para los scripts de restauración y comprobación.
DATABASE_BACKUP_DIR=backups
DATABASE_BUSY_TIMEOUT=5000
DATABASE_ENABLE_WAL=true
DATABASE_SYNCHRONOUS=NORMAL
DATABASE_WAL_AUTOCHECKPOINT=1000
DATABASE_JOURNAL_SIZE_LIMIT=67108864
DATABASE_BACKUP_MAX_AGE_HOURS=26
DATABASE_MIN_FREE_MB=1024
BACKUP_DAILY_RETENTION_DAYS=14
BACKUP_WEEKLY_RETENTION_WEEKS=8
BACKUP_MONTHLY_RETENTION_MONTHS=12
# La purga nunca se activa sin esta confirmación explícita.
BACKUP_PRUNE_ENABLED=false

CORS_ORIGIN=*

# Autenticación desactivada temporalmente. Cambia a true cuando quieras usarla.
AUTH_ENABLED=false
# Al activar AUTH_ENABLED, define también ADMIN_PASSWORD:
# Authorization: Bearer TU_PASSWORD
# o el header x-admin-password: TU_PASSWORD
ADMIN_PASSWORD=

# API externa del proyecto omkarcloud/airbnb-scraper.
# Obtén la clave en https://www.omkar.cloud/auth/sign-up?redirect=/api-key
AIRBNB_SCRAPER_API_URL=https://airbnb-scraper-api.omkar.cloud
AIRBNB_SCRAPER_API_KEY=
AIRBNB_SCRAPER_CURRENCY=USD
