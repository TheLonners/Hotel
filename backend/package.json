{
  "name": "hotel-reservas-backend",
  "version": "1.0.0",
  "description": "API local para gestion de reservas hoteleras con SQLite.",
  "main": "src/server.js",
  "type": "commonjs",
  "engines": {
    "node": ">=24"
  },
  "scripts": {
    "start": "node src/server.js",
    "dev": "node --watch src/server.js",
    "seed": "node src/database/seed.js",
    "backup": "node src/scripts/backup.js",
    "test:integrity": "node src/scripts/verify-reservation-integrity.js",
    "db:check": "node src/scripts/db-check.js",
    "db:backup": "node src/scripts/backup.js",
    "db:restore": "node src/scripts/db-restore.js",
    "db:test-restore": "node src/scripts/db-test-restore.js",
    "db:maintenance": "node src/scripts/db-maintenance.js",
    "db:concurrency": "node src/scripts/test-reservation-concurrency.js",
    "db:migrate": "node src/scripts/migrate.js"
  },
  "dependencies": {
    "cors": "^2.8.5",
    "dotenv": "^16.4.7",
    "express": "^4.21.2",
    "multer": "^2.0.2",
    "xlsx": "^0.18.5"
  },
  "devDependencies": {}
}
